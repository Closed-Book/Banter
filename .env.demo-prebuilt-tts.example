# 演示预制 TTS 模板：复制为 .env 后可无 key 运行固定 demo。
# 这个文件可以上传 GitHub；真实 .env 不要上传。

# 使用本地 mock 回合，避免演示现场依赖 LLM 网络与额度。
VITE_USE_MOCK=true

# 使用 public/demo-tts/ 下的预制音频，不调用实时 TTS API。
VITE_TTS_MODE=prebuilt
VITE_DEMO_TTS_BASE_URL=/demo-tts

# 演示模式不需要 key；保留空值是为了让开发者知道真实联调时要填哪些变量。
STEPFUN_BASE_URL=https://api.stepfun.com/v1
STEPFUN_ROLEPLAY_API_KEY=
STEPFUN_ROLEPLAY_MODEL=step-2-16k
VITE_STEPFUN_MODEL=step-2-16k
STEPFUN_VOICE_API_KEY=
STEPFUN_TTS_MODEL=stepaudio-2.5-tts
STEPFUN_ANALYSIS_API_KEY=
STEPFUN_ANALYSIS_MODEL=step-2-16k
