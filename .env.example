# 复制本文件为 .env 并填入真实值（.env 已被 gitignore，不会泄露）
# 阶跃星辰 API（OpenAI 兼容格式）
VITE_STEPFUN_API_KEY=sk-请填入你的key
VITE_STEPFUN_BASE_URL=https://api.stepfun.com/v1
VITE_STEPFUN_MODEL=step-3.7-flash
# 调用阶跃星辰的并发上限
VITE_STEPFUN_CONCURRENCY=5

# 为 true 时前端走 shared/mock-responses 假数据，不调真实 API。
# 联调前默认 true，让没有 key 的人也能空跑五屏。
VITE_USE_MOCK=true
