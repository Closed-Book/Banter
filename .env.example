# 复制本文件为 .env 并按需填入真实值（.env 已被 gitignore，不会泄露）

# TTS 专用服务端 key。语音播放走本地 /api/voice/tts，不要把这个 key 暴露到前端代码。
STEPFUN_VOICE_API_KEY=
STEPFUN_BASE_URL=https://api.stepfun.com/v1
STEPFUN_TTS_MODEL=stepaudio-2.5-tts

# 语言分析专用服务端 key。后续评分、复盘、表达分析走独立代理时使用。
STEPFUN_ANALYSIS_API_KEY=
STEPFUN_ANALYSIS_MODEL=step-2-16k

# 角色扮演聊天 API。陈总对话走本地 /api/roleplay/chat/completions，不要把这个 key 暴露到前端代码。
STEPFUN_ROLEPLAY_API_KEY=
STEPFUN_ROLEPLAY_MODEL=step-2-16k
VITE_STEPFUN_MODEL=step-2-16k

# 为 true 时前端走 shared/mock-responses 假数据，不调真实 API。
# 联调前默认 true，让没有 key 的人也能空跑五屏。
VITE_USE_MOCK=true

# TTS 运行模式：
# live = 走服务端实时 TTS 代理；prebuilt = 读取 public/demo-tts 预制音频；off = 关闭语音。
VITE_TTS_MODE=off
VITE_DEMO_TTS_BASE_URL=/demo-tts
